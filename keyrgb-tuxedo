#!/bin/bash
# Launcher for KeyRGB Tuxedo GUI with ITE backend
# Sets up proper Python path and launches the forked Tuxedo UI

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

export PYTHONPATH="$PWD/ite8291r3-ctl:$PYTHONPATH"

# Use the project venv if present, fall back to system python3.
if [ -x "$SCRIPT_DIR/.venv/bin/python" ]; then
    PYTHON="$SCRIPT_DIR/.venv/bin/python"
else
    PYTHON="python3"
fi

exec "$PYTHON" keyrgb-tuxedo-gui.py "$@"
